# Data files — ignore contents, keep folder structure
data/raw/*
data/processed/*
data/results/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/results/.gitkeep
*.sav
*.dta
*.parquet
*.pkl
*.pickle
*.h5
*.hdf5

# Output files — ignore contents, keep folders
outputs/*
logs/*
!outputs/.gitkeep
!logs/.gitkeep
*.log

# Visualizations
*.png
*.jpg
*.jpeg
*.gif
*.pdf

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyc
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Virtual environments
venv/
env/
.venv
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Environment variables
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
